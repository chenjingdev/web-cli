{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@agrune/core": ["packages/core/src/index.ts"],
      "@agrune/build-core": ["packages/build-core/src/index.ts"],
      "@agrune/build-core/runtime": ["packages/build-core/src/runtime/index.ts"],
      "@agrune/mcp-server": ["packages/mcp-server/src/index.ts"],
      "@agrune/extension": ["packages/extension/src/content/index.ts"]
    }
  }
}
