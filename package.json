{
  "name": "webcli-dom",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "build": "pnpm -r --filter \"@webcli-dom/*\" run build",
    "typecheck": "pnpm -r --filter \"@webcli-dom/*\" --if-present run typecheck && pnpm -r --filter \"@webcli-dom/*\" --if-present run build && pnpm -r --filter \"./apps/**\" --if-present run build",
    "test": "pnpm -r --filter \"@webcli-dom/*\" --if-present run test",
    "build:apps": "pnpm -r --filter \"./apps/**\" --if-present run build",
    "dev": "pnpm -C apps/cli-test-page dev",
    "dev:companion": "pnpm --filter @webcli-dom/companion run start"
  }
}
