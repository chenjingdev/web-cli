{
  "name": "@agrune/build-core",
  "version": "0.2.0",
  "private": true,
  "description": "Internal runtime primitives for the agrune extension",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "license": "MIT",
  "dependencies": {
    "@agrune/core": "workspace:*",
    "ai-motion": "0.4.8"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "jsdom": "^27.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
