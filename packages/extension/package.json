{
  "name": "@agrune/extension",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:manifest-version": "node ./scripts/sync-manifest-version.mjs",
    "prebuild": "pnpm run sync:manifest-version",
    "build": "vite build",
    "predev": "pnpm run sync:manifest-version",
    "dev": "vite build --watch",
    "pretypecheck": "pnpm run sync:manifest-version",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pretest": "pnpm run sync:manifest-version",
    "test": "vitest run"
  },
  "dependencies": {
    "@agrune/browser": "workspace:*",
    "@agrune/core": "workspace:*",
    "@agrune/devtools": "workspace:*",
    "@agrune/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "vite": "^6.0.0",
    "vitest": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
