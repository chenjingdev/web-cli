{
  "manifest_version": 3,
  "name": "webcli-dom",
  "version": "0.1.0",
  "description": "Browser automation for AI agents via annotated DOM elements",
  "permissions": ["nativeMessaging", "activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["dist/page-runtime.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
