{
  "manifest_version": 3,
  "name": "agrune",
  "version": "0.4.1",
  "key": "",
  "description": "Browser automation for AI agents via annotated DOM elements",
  "permissions": [
    "nativeMessaging",
    "activeTab",
    "scripting",
    "storage",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "128": "icon-128.png"
  },
  "background": {
    "service_worker": "dist/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "devtools_page": "src/devtools/devtools.html",
  "web_accessible_resources": [
    {
      "resources": [
        "dist/page-runtime.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
